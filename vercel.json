{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://api.statusline.sh/sitemap.xml" },
    { "source": "/robots.txt", "destination": "https://api.statusline.sh/robots.txt" },
    { "source": "/community", "destination": "/community.html" },
    { "source": "/builder", "destination": "/builder.html" },
    {
      "source": "/how-to-make-a-claude-code-statusline",
      "destination": "/how-to-make-a-claude-code-statusline.html"
    },
    {
      "source": "/claude-code-statusline-git-branch",
      "destination": "/claude-code-statusline-git-branch.html"
    },
    {
      "source": "/claude-code-statusline-token-usage",
      "destination": "/claude-code-statusline-token-usage.html"
    },
    {
      "source": "/claude-code-statusline-cost",
      "destination": "/claude-code-statusline-cost.html"
    },
    {
      "source": "/claude-code-statusline-model",
      "destination": "/claude-code-statusline-model.html"
    },
    {
      "source": "/claude-code-statusline-duration",
      "destination": "/claude-code-statusline-duration.html"
    },
    {
      "source": "/claude-code-statusline-rate-limit",
      "destination": "/claude-code-statusline-rate-limit.html"
    },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    {
      "source": "/community/:slug",
      "destination": "https://api.statusline.sh/ssr/community/:slug"
    },
    { "source": "/((?!_next|assets|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
